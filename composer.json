{
  "name": "owncloud/ocis",
  "config": {
    "platform": {
      "php": "8.4"
    },
    "vendor-dir": "./vendor-php",
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  },
  "require-dev": {
    "ext-simplexml": "*",
    "bamarni/composer-bin-plugin": "^1.8",
    "playwright-php/playwright": "^1.2"
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false
    }
  },
  "require": {
    "khanamiryan/qrcode-detector-decoder": "^2.0",
    "spomky-labs/otphp": "^11.5"
  }
}
