msgstr "Të shohë, shkarkojë dhe shfaqë krejt personat e ftuar."

#. UnifiedRole FileEditor, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:176
msgid "View, download, upload and edit."
msgstr "Të shohë, të shkarkojë, të ngarkojë dhe të përpunojë."

#. UnifiedRole EditorLite, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:142
msgid "View, download, upload, edit and add."
msgstr "Të shohë, të shkarkojë, të ngarkojë, të përpunojë dhe të shtojë."

#. UnifiedRole FileEditorListGrants, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:184
msgid "View, download, upload, edit and show all invited people."
msgstr ""
"Të shohë, të shkarkojë, të ngarkojë, të përpunojë dhe të shfaqë krejt "
"personat e ftuar."

#. UnifiedRole Editor, Role Description (resolves directly)
#. UnifiedRole SpaceEditorWithoutVersionsWithoutTrashbin, Role Description
#. (resolves directly)
#: pkg/unifiedrole/roles.go:150 pkg/unifiedrole/roles.go:226
msgid "View, download, upload, edit, add and delete."
msgstr "Të shohë, shkarkojë, ngarkojë, përpunojë, shtojë dhe fshijë."

#. UnifiedRole SpaceEditorWithoutTrashbin, Role Description (resolves
#. directly)
#: pkg/unifiedrole/roles.go:218
msgid "View, download, upload, edit, add and show all versions."
msgstr ""
"Të shohë, të shkarkojë, të ngarkojë, të përpunojë dhe të shfaqë krejt "
"versionet."

#. UnifiedRole SpaceEditorWithoutVersions, Role Description (resolves
#. directly)
#: pkg/unifiedrole/roles.go:210
msgid "View, download, upload, edit, add, delete and restore from trash bin."
msgstr ""
"Të shohë, shkarkojë, ngarkojë, përpunojë, shtojë, fshijë dhe rikthejë nga "
"kosh hedhurinash."

#. UnifiedRole EditorListGrants Editor, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:158
msgid "View, download, upload, edit, add, delete and show all invited people."
msgstr ""
"Të shohë, shkarkojë, ngarkojë, përpunojë, shtojë, fshijë dhe shfaqë krejt "
"personat e ftuar."

#. UnifiedRole SpaceEditor, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:234
msgid ""
"View, download, upload, edit, add, delete, show all versions and restore "
"from trash bin."
msgstr ""
"Të shohë, shkarkojë, ngarkojë, përpunojë, shtojë, fshijë, të shfaqë krejt "
"versionet dhe rikthejë nga kosh hedhurinash."

#. UnifiedRole Manager, Role Description (resolves directly)
#: pkg/unifiedrole/roles.go:242
msgid ""
"View, download, upload, edit, add, delete, show all versions, restore from "
"trash bin, empty the trash bin and manage members."
msgstr ""
"Të shohë, të shkarkojë, të ngarkojë, të përpunojë, të shtojë, të fshijë, të "
"shfaqë krejt versionet, të rikthejë nga kosh hedhurinash, të zbrazë kosh "
"hedhurinash dhe të administrojë anëtarë."

#. UnifiedRole EditorListGrantsWithVersions, Role Description (resolves
#. directly)
#: pkg/unifiedrole/roles.go:166
msgid ""
"View, download, upload, edit, delete, show all versions and all invited "
"people."
msgstr ""
"Të shohë, të shkarkojë, të ngarkojë, të përpunojë, të shfaqë krejt versionet"
" dhe krejt personat e ftuar."

#. UnifiedRole FileEditorListGrantsWithVersions, Role Description (resolves
#. directly)
#: pkg/unifiedrole/roles.go:192
msgid ""
"View, download, upload, edit, show all versions and all invited people."
msgstr ""
"Të shohë, shkarkojë, ngarkojë, përpunojë, të shfaqë krejt versionet dhe "
"krejt personat e ftuar."
